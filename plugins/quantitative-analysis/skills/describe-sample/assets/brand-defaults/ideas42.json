{
  "name": "ideas42",
  "version": "2026.03",
  "fonts": {
    "primary": "Figtree",
    "fallback": ["-apple-system", "BlinkMacSystemFont", "Segoe UI", "Arial", "sans-serif"],
    "weights": { "regular": 400, "semibold": 600, "bold": 700 },
    "font_file_dir": "assets/fonts"
  },
  "palette": {
    "primary":       "#004357",
    "primary_dark":  "#002633",
    "primary_light": "#0a6680",
    "accent":        "#7AC10A",
    "accent_alt":    "#1C8A70",
    "deep_sea":      "#087084",
    "warning":       "#EF6A00",
    "warning_light": "#FCAB38",
    "lichen":        "#D1E03B",
    "neutral_text":  "#3A3A3A",
    "neutral_grid":  "#D9E1E2",
    "neutral_muted": "#6B6B6B",
    "background":    "#FFFFFF"
  },
  "semantic": {
    "title":              "primary",
    "highlight":          "accent",
    "positive":           "accent",
    "negative":           "warning",
    "body_text":          "neutral_text",
    "grid_lines":         "neutral_grid",
    "footer_text":        "neutral_muted",
