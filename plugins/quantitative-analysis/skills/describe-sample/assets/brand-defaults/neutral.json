{
  "name": "neutral",
  "version": "1.0.0",
  "fonts": {
    "primary": "Calibri",
    "fallback": ["Arial", "sans-serif"],
    "weights": { "regular": 400, "semibold": 600, "bold": 700 },
    "font_file_dir": null
  },
  "palette": {
    "primary":       "#222222",
    "primary_dark":  "#111111",
    "primary_light": "#555555",
    "accent":        "#0066CC",
